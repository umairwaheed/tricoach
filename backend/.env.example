# Environment variables consumed by the backend.
#
# In the deployed environment these live in /etc/coaching-app/coaching-app.env on
# `internal-one` (not in this repo). This file documents the variables and their
# shapes.

# PostgreSQL — the single `coaching-app` database on internal-one (localhost there).
DATABASE_URL=postgres://coaching-app:<password>@127.0.0.1:5432/coaching-app

# Address the API binds to (nginx proxies to this port).
BIND_ADDR=127.0.0.1:3010

# JWT signing secret and token lifetime.
JWT_SECRET=<random-32-byte-hex>
JWT_TTL_HOURS=720

# Google Gemini. If unset, the deterministic rule-based coach is used, so the app
# runs with no API key.
# GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.0-flash

# Log verbosity.
RUST_LOG=info,tower_http=info,sqlx=warn
