# Copy to .env and adjust.

# --- Database (PostgreSQL) ---
# Local (docker compose): postgres://tricoach:tricoach@localhost:5432/tricoach
#
# Shared dev database on `internal-one` (Postgres is localhost-only there, so
# reach it through an SSH tunnel first):
#     ssh -f -N -L 5433:127.0.0.1:5432 internal-one
# then:
#     DATABASE_URL=postgres://tt-app:<password>@127.0.0.1:5433/tt-app
DATABASE_URL=postgres://tricoach:tricoach@localhost:5432/tricoach

# Address the API binds to
BIND_ADDR=0.0.0.0:8080

# JWT signing secret (CHANGE IN PRODUCTION) and token lifetime
JWT_SECRET=dev-insecure-change-me
JWT_TTL_HOURS=720

# Google Gemini. If unset, the deterministic rule-based coach is used instead,
# so the whole app runs fully offline with no API key.
# GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.0-flash

# Log verbosity
RUST_LOG=info,tower_http=info,sqlx=warn
